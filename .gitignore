# Unity / general
/Library/
/Temp/
/Logs/
/UserSettings/
/obj/

# Builds
/Build/
/Builds/

# Unity project/IDE files (regenerated by Unity)
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.sln.DotSettings.user

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
.vsconfig
*.iml

# Crash/analytics build artifacts
crashlytics-build.properties

# Mobile / package build outputs
*.apk
*.aab
*.unitypackage
*.app
*.exe

# Misc local logs
*.log

# Cursor-specific local settings (not needed to run the Unity project)
.cursorIgnore
.cursor/

# Generated Addressables / local streaming assets cache (if present)
/[Aa]ssets/[Ss]treamingAssets/aa/*
/[Aa]ssets/[Ss]treamingAssets/aa.meta

# OS junk
.DS_Store
Thumbs.db
